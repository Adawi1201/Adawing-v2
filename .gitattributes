# 强制 LF 换行（Linux 服务器用）
*.sh       text eol=lf
*.sql      text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.conf     text eol=lf

# Windows 批处理必须 CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf

# 二进制文件
*.jar      binary
*.png      binary
*.jpg      binary
*.gif      binary
*.ico      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
