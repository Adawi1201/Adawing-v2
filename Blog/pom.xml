<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>cc.adabyte</groupId>
        <artifactId>wing</artifactId>
        <version>1.0-SNAPSHOT</version>
    </parent>

    <artifactId>Blog</artifactId>
    <packaging>pom</packaging>

    <modules>
        <module>blog-common</module>
        <module>blog-resource</module>
        <module>blog-zoom</module>
        <module>blog-system</module>
        <module>blog-boot</module>
    </modules>

    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>blog-common</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>resource-core</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>resource-oss</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>resource-cleaner</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>zoom-shared</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>zoom-tag</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>zoom-article</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>zoom-note</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>zoom-message</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>system-auth</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>system-config</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cc.adabyte</groupId>
                <artifactId>system-review</artifactId>
                <version>${project.version}</version>
            </dependency>
            <!-- MyBatis-Plus 与 Spring Boot 3.5 兼容性：强制 mybatis-spring 3.x -->
            <dependency>
                <groupId>org.mybatis</groupId>
                <artifactId>mybatis-spring</artifactId>
                <version>3.0.4</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                    <parameters>true</parameters>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
