# AdaWing MCP Server 所需环境变量
# 将此文件内容追加到 ~/.bashrc / ~/.zshrc 或 Windows 系统环境变量

# 必须 — MCP API Key（通过 AdaWing 后台生成）
# 生成方式: POST http://<host>:8080/api/v2/mcp-keys
export ADAWING_MCP_KEY="mcp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 可选 — 如果 AdaWing 部署在非本地或非 8080 端口
export ADAWING_MCP_URL="http://localhost:8080/mcp"
